@page "/subjects"
@using EduCheck.Core.Entities
@using EduCheck.Core.Interfaces
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject ISubjectService SubjectService
@inject IJSRuntime JSRuntime

<PageTitle>Предметы</PageTitle>

<div class="d-flex justify-content-between mb-4">
    <h3>Предметы</h3>
    <button class="btn btn-primary" @onclick="() => OpenModal(null)">Добавить предмет</button>
</div>

<div class="row">
    @foreach (var s in subjects)
    {
        <div class="col-md-4 mb-3">
            <div class="card p-3 shadow-sm">
                <h5>@s.Title</h5>
                <p>Семестр: @s.Semester</p>
                <div class="d-flex flex-wrap gap-2 mt-auto pt-3">
                    <a href="/subject/@s.Id" class="btn btn-sm btn-info text-white">
                        <i class="bi bi-gear-fill me-1"></i>Управление
                    </a>
                    <button class="btn btn-sm btn-warning" @onclick="() => OpenModal(s)">
                        <i class="bi bi-pencil-square me-1"></i>Правка
                    </button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSubject(s.Id)">
                        <i class="bi bi-trash-fill me-1"></i>Удалить
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@if (showModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content p-4">
                <div class="modal-header"><h5>Предмет</h5></div>
                <div class="mb-3">
                    <label>Название</label>
                    <input @bind="form.Title" class="form-control" />
                </div>
                <div class="mb-3">
                    <label>Семестр</label>
                    <input @bind="form.Semester" type="number" class="form-control" />
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary" @onclick="Save">Сохранить</button>
                    <button class="btn btn-secondary" @onclick="() => showModal = false">Отмена</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Subject> subjects = new();
    private bool showModal;
    private SubjectFormModel form = new();

    public class SubjectFormModel
    {
        public Guid? Id { get; set; }
        public string Title { get; set; } = "";
        public int Semester { get; set; } = 1;
    }

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load() => subjects = await SubjectService.GetAllSubjectsAsync();

    private void OpenModal(Subject? s)
    {
        if (s == null) form = new SubjectFormModel();
        else form = new SubjectFormModel { Id = s.Id, Title = s.Title.ToString(), Semester = s.Semester };
        showModal = true;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(form.Title)) return;

        if (form.Id == null)
            await SubjectService.CreateSubjectAsync(form.Title, form.Semester);
        else
            await SubjectService.UpdateSubjectAsync(form.Id.Value, form.Title, form.Semester);
        
        showModal = false;
        await Load();
    }

    private async Task DeleteSubject(Guid id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Удалить предмет со всеми заданиями и работами?"))
        {
            await SubjectService.DeleteSubjectAsync(id);
            await Load();
        }
    }
}