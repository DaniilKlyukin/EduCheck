@page "/subjects"
@rendermode InteractiveServer
@using EduCheck.Core.Entities
@using EduCheck.Core.Interfaces
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@inject ISubjectService SubjectService
@inject IJSRuntime JSRuntime

<PageTitle>Предметы</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Учебные предметы</h3>
    <button class="btn btn-primary" @onclick="() => showCreateModal = true">Добавить предмет</button>
</div>

<div class="row">
    @foreach (var subject in subjects)
    {
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">@subject.Title</h5>
                    <h6 class="card-subtitle mb-2 text-muted">Семестр: @subject.Semester</h6>
                    <p class="card-text">Заданий: @subject.Assignments.Count</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="/subject/@subject.Id" class="btn btn-sm btn-outline-primary flex-fill">Управление</a>
                        <button class="btn btn-sm btn-outline-danger flex-fill" @onclick="() => DeleteSubject(subject.Id)">Удалить</button>
                        <button class="btn btn-sm btn-outline-primary flex-fill" @onclick="() => EditSubject(subject)">Редактировать</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (showCreateModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(isEditMode ? "Редактировать предмет" : "Новый предмет")</h5>
                    <button type="button" class="btn-close" @onclick="() => showCreateModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Название предмета</label>
                        <input @bind="newSubject.Title"
                               class="form-control"
                               placeholder="Например, ООП или Высшая математика" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Семестр</label>
                        <input @bind="newSubject.Semester"
                               type="number"
                               min="1"
                               max="12"
                               class="form-control"
                               placeholder="Введите номер семестра (1-12)" />
                        <div class="form-text">Укажите семестр, в котором преподается дисциплина.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showCreateModal = false">Отмена</button>
                    <button class="btn btn-primary" @onclick="SaveSubject">Сохранить</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool showCreateModal;
    private List<Subject> subjects = new();
    private Subject newSubject = new();
    private bool isEditMode;

    protected override async Task OnInitializedAsync()
    {
        subjects = await SubjectService.GetAllSubjectsAsync();
    }

    private void EditSubject(Subject s)
    {
        newSubject = new Subject { Id = s.Id, Title = s.Title, Semester = s.Semester };
        isEditMode = true;
        showCreateModal = true;
    }

    private async Task DeleteSubject(Guid id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            "Вы действительно хотите удалить этот предмет? Все связанные работы студентов будут безвозвратно удалены.");

        if (confirmed)
        {
            await SubjectService.DeleteSubjectAsync(id);

            subjects = await SubjectService.GetAllSubjectsAsync();
        }
    }

    private async Task SaveSubject()
    {
        if (string.IsNullOrWhiteSpace(newSubject.Title)) return;

        if (isEditMode)
            await SubjectService.UpdateSubjectAsync(newSubject);
        else
            await SubjectService.CreateSubjectAsync(newSubject);

        showCreateModal = false;
        isEditMode = false;
        newSubject = new();
        subjects = await SubjectService.GetAllSubjectsAsync();
    }
}