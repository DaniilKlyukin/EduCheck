@page "/submissions"
@using EduCheck.Application.DTOs
@using EduCheck.Core.Domain.Enums
@using EduCheck.Application.Interfaces
@using EduCheck.Web.Interfaces
@using EduCheck.Core.Primitives
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@inject ISubmissionService SubmissionService
@inject NavigationManager Nav
@inject ISubmissionStatusLabelProvider StatusLabelProvider
@inject ISubmissionStatusStyleProvider StatusStyleProvider

<PageTitle>Работы студентов - EduCheck</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Все работы</h1>
    <div class="text-muted small">Найдено: @FilteredSubmissions.Count()</div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body bg-light">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-bold">Группа</label>
                <input @bind="_filterGroup" @bind:event="oninput" placeholder="Поиск по группе..." class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold">Статус</label>
                <select @bind="_filterStatus" class="form-select form-select-sm">
                    <option value="">Все статусы</option>
                    @foreach (var status in Enum.GetValues<SubmissionStatus>())
                    {
                        <option value="@status">@StatusLabelProvider.GetDisplayName(status)</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <div class="form-check mb-2">
                    <input type="checkbox" @bind="_onlyLate" class="form-check-input" id="lateCheck" />
                    <label class="form-check-label small" for="lateCheck">Только просроченные</label>
                </div>
            </div>
            <div class="col-md-2 text-end">
                <button class="btn btn-sm btn-outline-secondary" @onclick="ResetFilters">Сброс</button>
            </div>
        </div>
    </div>
</div>

@if (_isLoading)
{
    <div class="text-center my-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Студент</th>
                        <th>Группа</th>
                        <th>Предмет / Задание</th>
                        <th>Версия</th>
                        <th>Статус</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sub in FilteredSubmissions)
                    {
                        <tr class="@(sub.HasLateUpload ? "table-danger-subtle" : "")">
                            <td>
                                <div class="fw-bold">@sub.StudentName</div>
                            </td>
                            <td><span class="badge bg-secondary">@sub.Group</span></td>
                            <td>
                                <div class="small text-muted">@sub.SubjectTitle</div>
                                <div>@sub.AssignmentTitle</div>
                            </td>
                            <td><span class="text-muted">@sub.Version</span></td>
                            <td>
                                <span class="badge rounded-pill @StatusStyleProvider.GetBadgeClass(sub.Status)">
                                    @StatusLabelProvider.GetDisplayName(sub.Status)
                                </span>
                                @if (sub.HasLateUpload)
                                {
                                    <span class="badge bg-danger ms-1" title="Загружено после дедлайна">
                                        <i class="bi bi-clock"></i>
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group shadow-sm">
                                    <button class="btn btn-sm btn-primary" @onclick='() => Nav.NavigateTo($"/review/{sub.Id}")'>
                                        <i class="bi bi-search me-1"></i> Проверить
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSubmission(sub)">
                                        <i class="bi bi-trash"></i> Удалить
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<SubmissionSummaryDto> _submissions = new();
    private string _filterGroup = "";
    private SubmissionStatus? _filterStatus;
    private bool _onlyLate;
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubmissions();
    }

    private async Task LoadSubmissions()
    {
        _isLoading = true;
        var result = await SubmissionService.GetAllSubmissionsAsync();
        
        if (result.IsSuccess)
        {
            _submissions = result.Value;
        }
        else
        {
            _errorMessage = result.Error.Message;
        }
        
        _isLoading = false;
    }

    private IEnumerable<SubmissionSummaryDto> FilteredSubmissions => _submissions
        .Where(s => string.IsNullOrEmpty(_filterGroup) || s.Group.Contains(_filterGroup, StringComparison.OrdinalIgnoreCase))
        .Where(s => _filterStatus == null || s.Status == _filterStatus)
        .Where(s => !_onlyLate || s.HasLateUpload);

    private void ResetFilters()
    {
        _filterGroup = "";
        _filterStatus = null;
        _onlyLate = false;
    }

    private async Task DeleteSubmission(SubmissionSummaryDto submission)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Удалить работу студента {submission.StudentName}? Это действие нельзя отменить.");
        
        if (confirmed)
        {
            var result = await SubmissionService.DeleteSubmissionAsync(submission.Id);
            if (result.IsSuccess)
            {
                _submissions.Remove(submission);
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {result.Error.Message}");
            }
        }
    }
}