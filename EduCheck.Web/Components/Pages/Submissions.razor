@page "/submissions"
@using EduCheck.Core.Common
@using EduCheck.Core.DTOs
@using EduCheck.Core.Enums
@using EduCheck.Core.Interfaces
@inject ISubmissionService SubmissionService
@inject NavigationManager Nav

<h3>Все работы</h3>

<div class="row mb-3">
    <div class="col">
        <input @bind="filterGroup" @bind:event="oninput" placeholder="Группа..." class="form-control" />
    </div>
    <div class="col">
        <select @bind="filterStatus" class="form-select">
            <option value="">Все статусы</option>
            @foreach (var status in Enum.GetValues<SubmissionStatus>())
            {
                <option value="@status">@status.GetDisplayName()</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <div class="form-check mt-2">
            <input type="checkbox" @bind="onlyLate" class="form-check-input" id="lateCheck" />
            <label class="form-check-label" for="lateCheck">Только просроченные</label>
        </div>
    </div>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Студент</th>
            <th>Группа</th>
            <th>Предмет / Задание</th>
            <th>Версия</th>
            <th>Статус</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var sub in FilteredSubmissions)
        {
            <tr class="@(sub.HasLateUpload ? "table-danger" : "")">
                <td>@sub.StudentName</td>
                <td>@sub.Group</td>
                <td>@sub.SubjectTitle / @sub.AssignmentTitle</td>
                <td>v@(sub.Version)</td>
                <td><span class="badge bg-info">@sub.Status.GetDisplayName()</span></td>
                <td>
                    <button class="btn btn-sm btn-primary" @onclick="() => Nav.NavigateTo($" /review/{sub.Id}")">Проверить</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<SubmissionSummaryDto> submissions = new();
    private string filterGroup = "";
    private SubmissionStatus? filterStatus;
    private bool onlyLate;

    protected override async Task OnInitializedAsync()
    {
        submissions = await SubmissionService.GetAllSubmissionsAsync();
    }

    private IEnumerable<SubmissionSummaryDto> FilteredSubmissions => submissions
        .Where(s => string.IsNullOrEmpty(filterGroup) || s.Group.Contains(filterGroup, StringComparison.OrdinalIgnoreCase))
        .Where(s => filterStatus == null || s.Status == filterStatus)
        .Where(s => !onlyLate || s.HasLateUpload);

}