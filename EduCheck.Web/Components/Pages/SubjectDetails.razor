@page "/subject/{Id:guid}"
@using EduCheck.Core.Entities
@using EduCheck.Core.Interfaces
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject ISubjectService SubjectService
@inject IJSRuntime JSRuntime

<PageTitle>Детали предмета</PageTitle>

@if (subject == null)
{
    <p>Загрузка...</p>
}
else
{
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/subjects">Предметы</a></li>
            <li class="breadcrumb-item active">@subject.Title</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3>@subject.Title</h3>
            <span class="badge bg-secondary">Семестр @subject.Semester</span>
        </div>
        <button class="btn btn-success" @onclick="OpenAddModal">+ Добавить задание</button>
    </div>

    <h4>Список заданий</h4>
    @if (!subject.Assignments.Any())
    {
        <div class="alert alert-info">В этом предмете еще нет ни одного задания.</div>
    }
    else
    {
        <div class="list-group mb-4">
            @foreach (var assignment in subject.Assignments.OrderBy(a => a.Deadline))
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">@assignment.Title</h5>
                        <small class="text-muted">Дедлайн: @assignment.Deadline.ToLocalTime().ToString("g")</small>
                    </div>
                    <div class="btn-group">
                        <button class="btn btn-sm btn-outline-info" @onclick="() => ShowDebtors(assignment.Id, assignment.Title)">Должники</button>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenEditModal(assignment)">Правка</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAssignment(assignment.Id)">Удалить</button>
                    </div>
                </div>
            }
        </div>
    }
    
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-light"><strong>Целевые группы</strong></div>
        <div class="card-body">
            <div class="d-flex gap-2 flex-wrap mb-3">
                @foreach (var tg in subject.TargetGroups)
                {
                    <span class="badge bg-info p-2">
                        @tg.GroupName
                        <button class="btn-close btn-close-white ms-2" style="font-size: 0.5rem;" @onclick="() => RemoveGroup(tg.Id)"></button>
                    </span>
                }
            </div>
            <div class="input-group mb-3" style="max-width: 300px;">
                <input @bind="newGroupName" class="form-control" placeholder="Группа..." />
                <button class="btn btn-primary" @onclick="AddGroup">Добавить</button>
            </div>
        </div>
    </div>
}

@if (showAssignmentModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header"><h5>Задание</h5></div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Название</label>
                        <input @bind="assignmentForm.Title" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Дедлайн</label>
                        <input type="datetime-local" @bind="assignmentForm.Deadline" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showAssignmentModal = false">Отмена</button>
                    <button class="btn btn-primary" @onclick="SaveAssignment">Сохранить</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDebtorsModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Не сдали: @selectedAssignmentTitle</h5>
                    <button class="btn-close" @onclick="() => showDebtorsModal = false"></button>
                </div>
                <div class="modal-body" style="max-height: 400px; overflow-y: auto;">
                    @if (debtors == null) { <p>Загрузка...</p> }
                    else if (!debtors.Any()) { <p class="text-success">Все сдали!</p> }
                    else {
                        <table class="table table-sm">
                            <thead><tr><th>Группа</th><th>ФИО</th><th>Email</th></tr></thead>
                            <tbody>
                                @foreach (var d in debtors) {
                                    <tr><td>@d.Group</td><td>@d.Name</td><td>@d.Email.Value</td></tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDebtorsModal = false">Закрыть</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private Subject? subject;
    private bool showAssignmentModal;
    private bool showDebtorsModal;
    private string? selectedAssignmentTitle;
    private List<Student>? debtors;
    private string newGroupName = "";
    private AssignmentFormModel assignmentForm = new();

    public class AssignmentFormModel
    {
        public Guid? Id { get; set; }
        public string Title { get; set; } = "";
        public DateTime Deadline { get; set; } = DateTime.Now.AddDays(7);
    }

    protected override async Task OnInitializedAsync() => await Load();
    private async Task Load() => subject = await SubjectService.GetSubjectByIdAsync(Id);

    private void OpenAddModal()
    {
        assignmentForm = new AssignmentFormModel();
        showAssignmentModal = true;
    }

    private void OpenEditModal(Assignment a) 
    {
        assignmentForm = new AssignmentFormModel { 
            Id = a.Id, 
            Title = a.Title, 
            Deadline = a.Deadline.ToLocalTime() 
        };
        showAssignmentModal = true;
    }

    private async Task SaveAssignment()
    {
        if (string.IsNullOrWhiteSpace(assignmentForm.Title)) return;

        try
        {
            if (assignmentForm.Id == null)
                await SubjectService.AddAssignmentAsync(Id, assignmentForm.Title, assignmentForm.Deadline.ToUniversalTime());
            else
                await SubjectService.UpdateAssignmentAsync(Id, assignmentForm.Id.Value, assignmentForm.Title, assignmentForm.Deadline.ToUniversalTime());

            showAssignmentModal = false;
            await Load();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Ошибка сохранения: " + ex.Message);
        }
    }

    private async Task DeleteAssignment(Guid aId)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Внимание! Будут удалены все работы студентов по этому заданию. Продолжить?");

        if (confirmed)
        {
            try
            {
                await SubjectService.DeleteAssignmentAsync(Id, aId);
                await Load();
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Ошибка удаления: " + ex.Message);
            }
        }
    }

    private async Task ShowDebtors(Guid aId, string title)
    {
        selectedAssignmentTitle = title;
        debtors = null;
        showDebtorsModal = true;
        debtors = await SubjectService.GetDebtorsAsync(aId);
    }

    private async Task AddGroup()
    {
        if (string.IsNullOrWhiteSpace(newGroupName)) return;

        try
        {
            await SubjectService.AddTargetGroupAsync(Id, newGroupName);
            newGroupName = "";
            await Load();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Не удалось добавить группу: " + ex.Message);
        }
    }

    private async Task RemoveGroup(Guid tgId)
    {
        await SubjectService.RemoveTargetGroupAsync(Id, tgId);
        await Load();
    }
}