@page "/review/{Id:guid}"
@using EduCheck.Core.Common
@using EduCheck.Core.Entities
@using EduCheck.Core.Interfaces
@inject ISubmissionService SubmissionService
@inject IEmailService EmailService
@inject NavigationManager Nav

@if (submission == null)
{
    <p>Загрузка...</p>
}
else
{
    <h3>Проверка: @submission.Student.Name (@submission.Student.Group)</h3>
    <h5>@submission.Assignment.Title — @submission.Assignment.Subject.Title</h5>

    <div class="row">
        <div class="col-md-6">
            <h4>История версий</h4>
            <ul class="list-group mb-3">
                @foreach (var h in submission.History.OrderByDescending(x => x.Version))
                {
                    <li class="list-group-item">
                        <b>v@h.Version</b> — @h.FileName (@h.ReceivedAt.ToLocalTime())
                        @if (h.IsLate)
                        {
                            <span class="badge bg-danger">Late</span>
                        }
                        <div class="mt-2 small text-muted">
                            <pre class="bg-light p-2">@h.AnalysisResult</pre>
                        </div>
                    </li>
                }
            </ul>
        </div>

        <div class="col-md-6">
            <h4>Выставить оценку</h4>
            <div class="card p-3">
                <div class="mb-3">
                    <label>Статус</label>
                    <select @bind="submission.Status" class="form-select">
                        @foreach (var status in Enum.GetValues<EduCheck.Core.Enums.SubmissionStatus>())
                        {
                            <option value="@status">@status.GetDisplayName()</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label>Оценка</label>
                    <input type="number" @bind="review.Grade" class="form-control" />
                </div>
                <div class="mb-3">
                    <label>Комментарий преподавателя</label>
                    <textarea @bind="review.TeacherComment" class="form-control" rows="4"></textarea>
                </div>
                <button class="btn btn-success" @onclick="SaveAndSend" disabled="@isSaving">
                    @(isSaving ? "Отправка..." : "Сохранить и отправить студенту")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private Submission? submission;
    private Review review = new();
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        submission = await SubmissionService.GetSubmissionByIdAsync(Id);

        if (submission != null)
        {
            review.SubmissionVersion = submission.CurrentVersion;
        }
    }

    private async Task SaveAndSend()
    {
        isSaving = true;
        await SubmissionService.SubmitReviewAsync(Id, review, submission.Status);
        isSaving = false;
        Nav.NavigateTo("/submissions");
    }
}