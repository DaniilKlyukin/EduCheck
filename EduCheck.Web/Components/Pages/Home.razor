@page "/"
@using EduCheck.Core.Interfaces
@using EduCheck.Core.Enums
@using Microsoft.AspNetCore.Components.Web
@inject ISubmissionService SubmissionService
@inject ISubjectService SubjectService

<PageTitle>Dashboard - EduCheck</PageTitle>

<div class="mb-4">
    <h1 class="h3">Обзор</h1>
    <p class="text-muted">Статистика учебного процесса на @DateTime.Now.ToString("D")</p>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card border-start border-primary border-4 shadow-sm h-100">
            <div class="card-body">
                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Ожидают проверки</div>
                <div class="h2 mb-0 font-weight-bold text-gray-800">@inReviewCount</div>
                <div class="mt-3">
                    <a href="/submissions" class="btn btn-sm btn-outline-primary">Просмотреть все</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card border-start border-danger border-4 shadow-sm h-100">
            <div class="card-body">
                <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Просрочено</div>
                <div class="h2 mb-0 font-weight-bold text-gray-800">@lateCount</div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card border-start border-success border-4 shadow-sm h-100">
            <div class="card-body">
                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Всего предметов</div>
                <div class="h2 mb-0 font-weight-bold text-gray-800">@subjectsCount</div>
                <div class="mt-3">
                    <a href="/subjects" class="btn btn-sm btn-outline-success">Управление</a>
                </div>
            </div>
        </div>
    </div>
</div>

@if (inReviewCount > 0)
{
    <div class="alert alert-info d-flex align-items-center" role="alert">
        <div>
            У вас есть необработанные работы студентов. Рекомендуется начать проверку с самых ранних загрузок.
        </div>
    </div>
}

@code {
    private int inReviewCount;
    private int lateCount;
    private int subjectsCount;

    protected override async Task OnInitializedAsync()
    {
        var submissions = await SubmissionService.GetAllSubmissionsAsync();
        var subjects = await SubjectService.GetAllSubjectsAsync();

        inReviewCount = submissions.Count(s => s.Status == SubmissionStatus.New || s.Status == SubmissionStatus.InReview);
        lateCount = submissions.Count(s => s.HasLateUpload);
        subjectsCount = subjects.Count;
    }
}